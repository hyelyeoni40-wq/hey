# Production environment variables — set these in the Vercel dashboard
# (Project Settings → Environment Variables), not in a committed .env file.
# This file documents what's required; it is not loaded automatically.

# PostgreSQL connection string from your production database provider
# (Vercel Postgres, Neon, Supabase, Railway, RDS, etc). Must be reachable
# from Vercel's serverless functions.
# If your provider uses connection pooling (pgbouncer), use the pooled
# connection string — @prisma/adapter-pg over `pg` works with standard
# Postgres wire protocol pooling.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Not needed at runtime. Only required if you run `prisma migrate dev` or
# `prisma migrate diff` locally against production-like schemas; omit in Vercel.
# SHADOW_DATABASE_URL=""

# Secret key used to sign/encrypt session JWTs. Generate with:
#   openssl rand -base64 32
# Must be a strong, unique value — never reuse the local dev secret.
SESSION_SECRET=""

# Real SMTP credentials for sending notification emails. If left unset,
# emails are silently logged instead of sent (fine for staging, not for
# production).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@yourdomain.com"

# The deployed app's public URL, used to build links in outgoing emails.
# Set to your production domain, e.g. https://your-app.vercel.app
APP_URL="https://your-app.vercel.app"

# Shared secret protecting POST/GET /api/notifications/run-reminders.
# Generate with: openssl rand -base64 32
# When this env var is named exactly CRON_SECRET, Vercel Cron Jobs (see
# vercel.json) automatically send it as `Authorization: Bearer $CRON_SECRET`,
# so no extra configuration is needed beyond setting this value.
CRON_SECRET=""
