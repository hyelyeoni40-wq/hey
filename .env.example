# PostgreSQL connection string.
# For local dev you can run `npx prisma dev` (bundled local Postgres) and paste
# the printed connection string here, or point to your own PostgreSQL instance.
DATABASE_URL="postgresql://user:password@localhost:5432/student_assessment?schema=public"
# Only needed for `prisma migrate dev`/`migrate diff` (shadow DB for diffing migrations).
# When using `npx prisma dev`, it prints a SHADOW_DATABASE_URL you can paste here.
SHADOW_DATABASE_URL=""

# Secret key used to sign/encrypt session JWTs. Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-strong-random-value"

# Email (SMTP) settings for notifications
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@example.com"

# Base URL used to build links in outgoing emails
APP_URL="http://localhost:3000"

# Shared secret required in the x-cron-secret header to call
# /api/notifications/run-reminders (meant to be invoked by an external scheduler)
CRON_SECRET="replace-with-a-strong-random-value"
